# syntax=docker/dockerfile:1.7
# Tiny invitation-email server (server/index.mjs) — Express + Resend, no DB.
# Keeps RESEND_API_KEY server-side only; the frontend POSTs to
# /api/invitations/send (routed here by Caddy).
FROM node:22-alpine
WORKDIR /app
COPY server/package.json ./
RUN npm install --omit=dev
COPY server/index.mjs ./
ENV PORT=8787
EXPOSE 8787
CMD ["node", "index.mjs"]
