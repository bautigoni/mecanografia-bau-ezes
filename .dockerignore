# Dependencies & build output (regenerated inside the image).
node_modules
dist
dist-ssr

# VCS / editor / OS clutter.
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store
Thumbs.db

# Local environment files — never bake secrets into the image.
.env
.env.*
!.env.example

# Logs.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Docker-related local files (not needed inside the build context).
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Local working folders & docs not needed in the runtime image.
Images
Images-new
Skills
DEPLOY.md
README.md
CLAUDE.md

# Secrets — never bake them into the image. They are mounted at
# runtime via Docker compose `secrets:` (see docker-compose.yml).
secrets/*
!secrets/.gitignore
!secrets/README.md

# TypeScript / build caches.
*.tsbuildinfo
.cache
.tmp

# Claude/agent scratch.
.claude
