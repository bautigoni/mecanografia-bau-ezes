# ====================================================================
# TYPELY — example environment file. Copy to `.env` and fill in real
# values. `.env` is gitignored — never commit real secrets.
# ====================================================================

# Google Identity Services Client ID (frontend / public).
# This is the OAuth 2.0 "Web application" Client ID from Google Cloud
# Console → APIs & Services → Credentials.
# Safe to embed in the frontend bundle (it is a public identifier).
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Optional comma-separated allowlist of institutional email domains.
# Leave empty (or omit) to allow any domain during development.
# Example: VITE_GOOGLE_ALLOWED_DOMAINS=northfield.edu.ar,reditinere.com
VITE_GOOGLE_ALLOWED_DOMAINS=

# ====================================================================
# SECURITY: NEVER put the Google Client SECRET in this file or in any
# frontend code. The client secret is only used by a backend during an
# OAuth code exchange; this app does not have such a backend, so the
# secret must NOT live in this repo at all.
# ====================================================================

# ====================================================================
# Backend (api) — these are read by the Fastify container, not by
# Vite. The DATABASE_URL / JWT_SECRET / RESEND_API_KEY are normally
# passed via Docker Compose `secrets:` (see docker-compose.yml). They
# are listed here for local development.
# ====================================================================

# Full Postgres connection string for the API service. The compose
# service `db` exposes it on 127.0.0.1:5432 to other containers.
# Example: postgres://typely:CHANGEME@db:5432/typely
DATABASE_URL=postgres://typely:typely@db:5432/typely

# 64+ random bytes. Generate with: openssl rand -base64 64
JWT_SECRET=replace-me-with-64-random-bytes

# Optional. If unset, the /api/invitations/send endpoint returns 503
# and the frontend falls back to a shareable invite link.
RESEND_API_KEY=re_LNE5X496_MQDSiYguxURZUb5mQSHA9LtM

# Used to sign the "From:" header of invitation emails.
INVITE_FROM=Typely <no-reply@typely.bauhub.online>

# Origin allowed by CORS. In production this is the public hostname.
CORS_ORIGIN=https://typely.bauhub.online

# Used by `node api/dist/seed.js` to create the canonical superadmin
# on first deploy. CHANGE THE PASSWORD before going to production.
SUPERADMIN_EMAIL=bautistagoni@northfield.edu.ar
SUPERADMIN_PASSWORD=admin
SUPERADMIN_NAME=Bautista Goni
