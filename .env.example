# ====================================================================
# TYPELY — example environment file. Copy to `.env` and fill in real
# values. `.env` is gitignored — never commit real secrets.
# ====================================================================

# Google Identity Services Client ID (frontend / public).
# This is the OAuth 2.0 "Web application" Client ID from Google Cloud
# Console → APIs & Services → Credentials.
# Safe to embed in the frontend bundle (it is a public identifier).
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Optional comma-separated allowlist of institutional email domains.
# Leave empty (or omit) to allow any domain during development.
# Example: VITE_GOOGLE_ALLOWED_DOMAINS=northfield.edu.ar,reditinere.com
VITE_GOOGLE_ALLOWED_DOMAINS=

# ====================================================================
# SECURITY: NEVER put the Google Client SECRET in this file or in any
# frontend code. The client secret is only used by a backend during an
# OAuth code exchange; this app does not have such a backend, so the
# secret must NOT live in this repo at all.
# ====================================================================
