# syntax=docker/dockerfile:1.7
# API image for the TYPELY backend — Fastify + Drizzle on Node 22.
#
# IMPORTANT: the API has its OWN dependency tree (api/package.json:
# fastify, drizzle-orm, postgres, bcrypt, …). It must be installed from
# THAT manifest — NOT the root Vite app's package.json.

# ---------- Builder ----------
FROM node:22-alpine AS builder
WORKDIR /app/api

# Reproducible install against the API's own lockfile.
COPY api/package.json api/package-lock.json ./
RUN npm ci

# API sources + tsconfig, then compile to ./dist.
COPY api/ ./
RUN npx tsc -p tsconfig.json

# ---------- Runtime ----------
FROM node:22-alpine AS runtime
WORKDIR /app/api
ENV NODE_ENV=production

COPY --from=builder /app/api/node_modules ./node_modules
COPY --from=builder /app/api/dist ./dist
COPY --from=builder /app/api/package.json ./package.json

EXPOSE 3000

# Read *_FILE secrets (mounted by compose at /run/secrets/*) into the env
# vars the app expects, then start. GOOGLE_CLIENT_ID / INVITE_FROM come in
# as plain env vars from compose and need no translation.
CMD ["sh", "-c", "for v in DATABASE_URL JWT_SECRET RESEND_API_KEY; do eval f=\\$${v}_FILE; if [ -n \"$f\" ] && [ -f \"$f\" ]; then export $v=\"$(cat \"$f\")\"; fi; done; exec node dist/server.js"]
